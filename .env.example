DATABASE_URL=postgresql://user:password@host:5432/dbname
OPENAI_API_KEY=sk-...
NEWS_API_KEY=your_newsapi_key
TAVILY_API_KEY=your_tavily_api_key

# Vercel sets this automatically for cron job auth — do NOT set it manually in production.
# For local testing of /api/cron/daily, set any string here and pass it as:
#   curl -H "Authorization: Bearer <value>" http://localhost:3000/api/cron/daily
CRON_SECRET=

